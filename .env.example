OPENAI_API_KEY=your-openai-api-key-here
PORT=4000

# Free-tier usage resets every Monday at this local time (no cron needed; computed on each request).
# USAGE_RESET_TZ=Europe/Kyiv
# USAGE_RESET_HOUR=8
# USAGE_RESET_MINUTE=0

# Optional: persist entitlements in Firebase Realtime Database (survives server restart).
# If not set, entitlements are stored in memory only.
# FIREBASE_DATABASE_URL=https://plant-doctor-ai-a383c-default-rtdb.firebaseio.com
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}

# Purchase verification (production: set REQUIRE_PURCHASE_VERIFICATION=true)
# REQUIRE_PURCHASE_VERIFICATION=false
# REQUIRE_ANDROID_PURCHASE_VERIFICATION=false
# GOOGLE_PLAY_PACKAGE_NAME=com.sych.plantdoctor
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# APP_STORE_SHARED_SECRET=
# APP_STORE_BUNDLE_ID=
